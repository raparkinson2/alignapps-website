{
  "expo": {
    "name": "Align Sports",
    "slug": "align-sports",
    "scheme": "alignsports",
    "version": "9.4.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibecode.alignsports-jy5wjr",
      "buildNumber": "141",
      "entitlements": {
        "aps-environment": "production",
        "com.apple.developer.applesignin": [
          "Default"
        ],
        "com.apple.developer.associated-domains": [
          "applinks:alignapps.com"
        ]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Align Sports uses the camera to capture photos inside the app before you publish them.",
        "NSPhotoLibraryUsageDescription": "Align Sports accesses your photo library to let you choose media that appears in the app.",
        "NSLocationWhenInUseUsageDescription": "Align Sports uses your location to show nearby content and services while you use the app.",
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.vibecode.alignsports",
      "versionCode": 8
    },
    "extra": {
      "eas": {
        "projectId": "727371d5-f124-42e2-af0e-40f420477bce"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "icon": "./icon.png"
  }
}
